@using EPiServer.Framework.Web.Mvc.Html
@using EPiServer.Shell.Navigation
@using PreciseAlloy.Web.Generated
<!DOCTYPE html>
<html lang="@ContentLanguage.PreferredCulture.TwoLetterISOLanguageName">

@* ReSharper disable once MissingTitleTag *@
<head>
    @await Component.InvokeAsync("MetaData")
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="@AssetPaths.StyleBaseCss">

    <script src="@AssetPaths.MainJs"></script>
    @Html.RequiredClientResources("Header")

    <script type="module" src="@AssetPaths.WidgetReactLoaderJs"></script>

    <!-- Shell -->
    @ClientResources.RenderResources("ShellCore")

    <!-- LightTheme -->
    @ClientResources.RenderResources("ShellCoreLightTheme")
</head>

<body>
    @Html.CreatePlatformNavigationMenu()
    <main @Html.ApplyPlatformNavigation()>
        @RenderBody()
    </main>
</body>

</html>